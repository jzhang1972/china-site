---
import Layout from "../layouts/Layout.astro";
---

<Layout 
  title="China Tours & Local Guides · Book Your Trip" 
  description="Group tours, private guides, and custom itineraries. Experience China with trusted local operators."
>
    <a href="/" style="display: inline-block; margin-bottom: 2rem; color: #2D6A4F;">← Back to Home</a>
    
    <!-- 标题区 -->
    <h1>Prefer a local guide?</h1>
    <p style="font-size: 1.2rem; margin-bottom: 2.5rem;">Let someone else do the job. You just show up.</p>
    
    <!-- 分流区 -->
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 3rem;">
      
      <!-- Group Tours 卡片 -->
      <div style="background: #FFFFFF; border-radius: 16px; padding: 1.5rem; border: 1px solid #E2E0D4; text-align: center;">
        <h3 style="margin: 0 0 0.3rem 0; font-size: 1.3rem;">🏛️ Group Tours</h3>
        <p style="margin: 0 0 0.3rem 0; font-size: 0.9rem; color: #5a6b5a;">Fixed dates · Travel with others</p>
        <p style="margin: 0 0 1rem 0; font-size: 0.9rem; color: #5a6b5a;">No planning needed. Just book and go.</p>
        <div style="display: flex; flex-wrap: wrap; gap: 0.8rem; justify-content: center;">
          <a href="https://www.trip.com/t/PEpvpRQHQV2" target="_blank" rel="noopener noreferrer" style="background-color: #0078FF; color: white; padding: 0.4rem 1.2rem; border-radius: 20px; text-decoration: none; font-size: 0.85rem; display: inline-block; border: 1px solid #0078FF; transition: background-color 0.2s, transform 0.1s;" onmouseover="this.style.backgroundColor='#0050CC'; this.style.transform='translateY(-1px)'" onmouseout="this.style.backgroundColor='#0078FF'; this.style.transform='translateY(0)'">Trip.com →</a>
          <a href="https://gyg.me/xtOWfDVf" target="_blank" rel="noopener noreferrer" style="background-color: #00A651; color: white; padding: 0.4rem 1.2rem; border-radius: 20px; text-decoration: none; font-size: 0.85rem; display: inline-block; border: 1px solid #00A651; transition: background-color 0.2s, transform 0.1s;" onmouseover="this.style.backgroundColor='#008040'; this.style.transform='translateY(-1px)'" onmouseout="this.style.backgroundColor='#00A651'; this.style.transform='translateY(0)'">GetYourGuide →</a>
        </div>
      </div>
      
      <!-- Custom & Private 卡片 -->
      <div style="background: #FFFFFF; border-radius: 16px; padding: 1.5rem; border: 1px solid #E2E0D4; text-align: center;">
        <h3 style="margin: 0 0 0.3rem 0; font-size: 1.3rem;">🎯 Custom & Private</h3>
        <p style="margin: 0 0 0.3rem 0; font-size: 0.9rem; color: #5a6b5a;">Flexible itinerary · Your own pace</p>
        <p style="margin: 0 0 1rem 0; font-size: 0.9rem; color: #5a6b5a;">Private guide. Built around you.</p>
        <div style="display: flex; flex-wrap: wrap; gap: 0.8rem; justify-content: center;">
          <a href="https://www.trip.com/t/I1Mk9qyGQV2" target="_blank" rel="noopener noreferrer" style="background-color: #0078FF; color: white; padding: 0.4rem 1.2rem; border-radius: 20px; text-decoration: none; font-size: 0.85rem; display: inline-block; border: 1px solid #0078FF; transition: background-color 0.2s, transform 0.1s;" onmouseover="this.style.backgroundColor='#0050CC'; this.style.transform='translateY(-1px)'" onmouseout="this.style.backgroundColor='#0078FF'; this.style.transform='translateY(0)'">Trip.com →</a>
          <a href="https://gyg.me/xtOWfDVf" target="_blank" rel="noopener noreferrer" style="background-color: #00A651; color: white; padding: 0.4rem 1.2rem; border-radius: 20px; text-decoration: none; font-size: 0.85rem; display: inline-block; border: 1px solid #00A651; transition: background-color 0.2s, transform 0.1s;" onmouseover="this.style.backgroundColor='#008040'; this.style.transform='translateY(-1px)'" onmouseout="this.style.backgroundColor='#00A651'; this.style.transform='translateY(0)'">GetYourGuide →</a>
        </div>
      </div>
      
    </div>
    
    <!-- 热门产品 -->
    <h2 style="font-size: 1.5rem; margin-bottom: 1.5rem;">Popular Tours</h2>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; margin-bottom: 3rem;">
      
      <!-- 1. Classic China -->
      <a href="https://sg.trip.com/package-tours/detail/68474858?city=1&Allianceid=5609710&SID=130343298&trip_sub1=&trip_sub3=D18560194" target="_blank" rel="noopener noreferrer" style="text-decoration: none; color: inherit; display: flex;">
        <div style="background: #FFFFFF; border-radius: 16px; overflow: hidden; border: 1px solid #E2E0D4; width: 100%; display: flex; flex-direction: column; min-height: 500px;">
          <img 
            src="/images/tours/terracotta-warriors-xian-china-tour.webp" 
            alt="Terracotta Warriors in Xi'an" 
            loading="lazy"
            style="width: 100%; height: 160px; object-fit: cover; display: block;">
          <div style="padding: 1.2rem; flex: 1; display: flex; flex-direction: column;">
            <h3 style="margin: 0 0 0.3rem 0;">Classic China</h3>
            <p style="margin: 0 0 0.3rem 0; font-size: 0.9rem; color: #5a6b5a;">8 days · Beijing → Xi'an → Shanghai</p>
            <p style="margin: 0 0 1rem 0; font-size: 0.9rem; flex: 1;">Forbidden City, Great Wall, Terracotta Warriors, and modern Shanghai.</p>
            <div style="margin-top: 0.8rem;">
              <span style="display: inline-block; background-color: #2D6A4F; color: white; padding: 0.3rem 1rem; border-radius: 20px; font-size: 0.85rem;">View tour →</span>
            </div>
          </div>
        </div>
      </a>
      
      <!-- 2. Panda Explorer -->
      <a href="https://sg.trip.com/package-tours/detail/69509194?city=28&Allianceid=5609710&SID=130343298&trip_sub1=&trip_sub3=D18560194" target="_blank" rel="noopener noreferrer" style="text-decoration: none; color: inherit; display: flex;">
        <div style="background: #FFFFFF; border-radius: 16px; overflow: hidden; border: 1px solid #E2E0D4; width: 100%; display: flex; flex-direction: column; min-height: 500px;">
          <img 
            src="/images/tours/giant-panda-chengdu-china-tour.webp" 
            alt="Giant panda in Chengdu" 
            loading="lazy"
            style="width: 100%; height: 160px; object-fit: cover; display: block;">
          <div style="padding: 1.2rem; flex: 1; display: flex; flex-direction: column;">
            <h3 style="margin: 0 0 0.3rem 0;">Panda Explorer</h3>
            <p style="margin: 0 0 0.3rem 0; font-size: 0.9rem; color: #5a6b5a;">5 days · Chengdu</p>
            <p style="margin: 0 0 1rem 0; font-size: 0.9rem; flex: 1;">Giant pandas, Leshan Giant Buddha, spicy hotpot, and Sichuan culture.</p>
            <div style="margin-top: 0.8rem;">
              <span style="display: inline-block; background-color: #2D6A4F; color: white; padding: 0.3rem 1rem; border-radius: 20px; font-size: 0.85rem;">View tour →</span>
            </div>
          </div>
        </div>
      </a>
      
      <!-- 3. Yangtze River Cruise -->
      <a href="https://sg.trip.com/package-tours/detail/68183497?city=4" target="_blank" rel="noopener noreferrer" style="text-decoration: none; color: inherit; display: flex;">
        <div style="background: #FFFFFF; border-radius: 16px; overflow: hidden; border: 1px solid #E2E0D4; width: 100%; display: flex; flex-direction: column; min-height: 500px;">
          <img 
            src="/images/tours/yangtze-river-three-gorges-cruise-china-tour.webp" 
            alt="Yangtze River Three Gorges" 
            loading="lazy"
            style="width: 100%; height: 160px; object-fit: cover; display: block;">
          <div style="padding: 1.2rem; flex: 1; display: flex; flex-direction: column;">
            <h3 style="margin: 0 0 0.3rem 0;">Yangtze River Cruise</h3>
            <p style="margin: 0 0 0.3rem 0; font-size: 0.9rem; color: #5a6b5a;">7 days · Chongqing + Yangtze River Three Gorges + Wuhan</p>
            <p style="margin: 0 0 1rem 0; font-size: 0.9rem; flex: 1;">Three Gorges, onboard luxury, and ancient towns along the river.</p>
            <div style="margin-top: 0.8rem;">
              <span style="display: inline-block; background-color: #2D6A4F; color: white; padding: 0.3rem 1rem; border-radius: 20px; font-size: 0.85rem;">View tour →</span>
            </div>
          </div>
        </div>
      </a>
      
      <!-- 4. Zhangjiajie Avatar Tour -->
      <a href="https://www.trip.com/package-tours/detail/66933224?city=27&Allianceid=5609710&SID=130343298&trip_sub1=&trip_sub3=D18582321" target="_blank" rel="noopener noreferrer" style="text-decoration: none; color: inherit; display: flex;">
        <div style="background: #FFFFFF; border-radius: 16px; overflow: hidden; border: 1px solid #E2E0D4; width: 100%; display: flex; flex-direction: column; min-height: 500px;">
          <img 
            src="/images/tours/avatar-mountains-zhangjiajie-wulingyuan-china-tour.webp" 
            alt="Avatar Mountains Zhangjiajie" 
            loading="lazy"
            style="width: 100%; height: 160px; object-fit: cover; display: block;">
          <div style="padding: 1.2rem; flex: 1; display: flex; flex-direction: column;">
            <h3 style="margin: 0 0 0.3rem 0;">Zhangjiajie Avatar Tour</h3>
            <p style="margin: 0 0 0.3rem 0; font-size: 0.9rem; color: #5a6b5a;">3-5 days · Zhangjiajie</p>
            <p style="margin: 0 0 1rem 0; font-size: 0.9rem; flex: 1;">Walk among the floating mountains that inspired the movie Avatar.</p>
            <div style="margin-top: 0.8rem;">
              <span style="display: inline-block; background-color: #2D6A4F; color: white; padding: 0.3rem 1rem; border-radius: 20px; font-size: 0.85rem;">View tour →</span>
            </div>
          </div>
        </div>
      </a>
      
      <!-- 5. Tibet Group Tour -->
      <a href="https://www.trip.com/package-tours/detail/68427915?city=41" target="_blank" rel="noopener noreferrer" style="text-decoration: none; color: inherit; display: flex;">
        <div style="background: #FFFFFF; border-radius: 16px; overflow: hidden; border: 1px solid #E2E0D4; width: 100%; display: flex; flex-direction: column; min-height: 500px;">
          <img 
            src="/images/tours/potala-palace-lhasa-tibet-china-tour.webp" 
            alt="Potala Palace Lhasa Tibet" 
            loading="lazy"
            style="width: 100%; height: 160px; object-fit: cover; display: block;">
          <div style="padding: 1.2rem; flex: 1; display: flex; flex-direction: column;">
            <h3 style="margin: 0 0 0.3rem 0;">Tibet Group Tour</h3>
            <p style="margin: 0 0 0.3rem 0; font-size: 0.9rem; color: #5a6b5a;">8-10 days · Lhasa → Everest Base Camp</p>
            <p style="margin: 0 0 1rem 0; font-size: 0.9rem; flex: 1;">Potala Palace, Tibetan monasteries, and the roof of the world.</p>
            <div style="margin-top: 0.8rem;">
              <span style="display: inline-block; background-color: #2D6A4F; color: white; padding: 0.3rem 1rem; border-radius: 20px; font-size: 0.85rem;">View tour →</span>
            </div>
          </div>
        </div>
      </a>
      
      <!-- 6. Silk Road Explorer -->
      <a href="https://www.trip.com/package-tours/detail/71861405?city=39&Allianceid=5609710&SID=130343298&trip_sub1=&trip_sub3=D18582321" target="_blank" rel="noopener noreferrer" style="text-decoration: none; color: inherit; display: flex;">
        <div style="background: #FFFFFF; border-radius: 16px; overflow: hidden; border: 1px solid #E2E0D4; width: 100%; display: flex; flex-direction: column; min-height: 500px;">
          <img 
            src="/images/tours/dunhuang-mogao-caves-silk-road-china-tour.webp" 
            alt="Dunhuang Mogao Caves Silk Road" 
            loading="lazy"
            style="width: 100%; height: 160px; object-fit: cover; display: block;">
          <div style="padding: 1.2rem; flex: 1; display: flex; flex-direction: column;">
            <h3 style="margin: 0 0 0.3rem 0;">Silk Road Explorer</h3>
            <p style="margin: 0 0 0.3rem 0; font-size: 0.9rem; color: #5a6b5a;">10-14 days · Xi'an → Dunhuang → Kashgar</p>
            <p style="margin: 0 0 1rem 0; font-size: 0.9rem; flex: 1;">Mogao Caves, desert camels, and the ancient Silk Road.</p>
            <div style="margin-top: 0.8rem;">
              <span style="display: inline-block; background-color: #2D6A4F; color: white; padding: 0.3rem 1rem; border-radius: 20px; font-size: 0.85rem;">View tour →</span>
            </div>
          </div>
        </div>
      </a>
      
      <!-- 7. Chengdu & Jiuzhaigou -->
      <a href="https://www.getyourguide.com/chengdu-l1697/9-day-tour-through-wudangchengdudujiangyanzhangjiajie-t938590/?partner_id=JTUUOEV&utm_medium=travel_agent" target="_blank" rel="noopener noreferrer" style="text-decoration: none; color: inherit; display: flex;">
        <div style="background: #FFFFFF; border-radius: 16px; overflow: hidden; border: 1px solid #E2E0D4; width: 100%; display: flex; flex-direction: column; min-height: 500px;">
          <img 
            src="/images/tours/jiuzhaigou-valley-autumn-sichuan-china-tour.webp" 
            alt="Jiuzhaigou Valley autumn" 
            loading="lazy"
            style="width: 100%; height: 160px; object-fit: cover; display: block;">
          <div style="padding: 1.2rem; flex: 1; display: flex; flex-direction: column;">
            <h3 style="margin: 0 0 0.3rem 0;">Chengdu & Jiuzhaigou</h3>
            <p style="margin: 0 0 0.3rem 0; font-size: 0.9rem; color: #5a6b5a;">7-9 days · Chengdu → Jiuzhaigou</p>
            <p style="margin: 0 0 1rem 0; font-size: 0.9rem; flex: 1;">Pandas, hotpot, and turquoise lakes. A UNESCO World Heritage site with waterfalls, colorful lakes, and snow-capped peaks.</p>
            <div style="font-size: 0.8rem; color: #6c757d; background: #f8f6f0; padding: 0.5rem; border-radius: 6px; margin: 0.5rem 0;">
              <strong>ℹ️ Visa note:</strong> Jiuzhaigou is not covered by the 240-hour transit visa. A standard tourist visa is required.
            </div>
            <div style="margin-top: 0.5rem;">
              <span style="display: inline-block; background-color: #2D6A4F; color: white; padding: 0.3rem 1rem; border-radius: 20px; font-size: 0.85rem;">View tour →</span>
            </div>
          </div>
        </div>
      </a>
      
      <!-- 8. Yunnan Discovery -->
      <a href="https://www.getyourguide.com/lijiang-l1075/8-day-kunming-dali-lijiang-shangri-la-small-group-tour-t1370637/?partner_id=JTUUOEV&utm_medium=travel_agent" target="_blank" rel="noopener noreferrer" style="text-decoration: none; color: inherit; display: flex;">
        <div style="background: #FFFFFF; border-radius: 16px; overflow: hidden; border: 1px solid #E2E0D4; width: 100%; display: flex; flex-direction: column; min-height: 500px;">
          <img 
            src="/images/tours/lijiang-old-town-yunnan-china-tour.webp" 
            alt="Lijiang Old Town Yunnan" 
            loading="lazy"
            style="width: 100%; height: 160px; object-fit: cover; display: block;">
          <div style="padding: 1.2rem; flex: 1; display: flex; flex-direction: column;">
            <h3 style="margin: 0 0 0.3rem 0;">Yunnan Discovery</h3>
            <p style="margin: 0 0 0.3rem 0; font-size: 0.9rem; color: #5a6b5a;">8-10 days · Kunming → Dali → Lijiang</p>
            <p style="margin: 0 0 1rem 0; font-size: 0.9rem; flex: 1;">Slow travel through China's most colorful province. Cycle through Dali's rice fields, wander Lijiang's old town, and sip tea with the Bai people.</p>
            <div style="margin-top: 0.8rem;">
              <span style="display: inline-block; background-color: #2D6A4F; color: white; padding: 0.3rem 1rem; border-radius: 20px; font-size: 0.85rem;">View tour →</span>
            </div>
          </div>
        </div>
      </a>
      
      <!-- 9. Guangzhou & Macau -->
      <a href="https://www.getyourguide.com/guangzhou-l184/guangzhou-adventure-culture-cuisine-5-day-trip-t965262/?partner_id=JTUUOEV&utm_medium=travel_agent" target="_blank" rel="noopener noreferrer" style="text-decoration: none; color: inherit; display: flex;">
        <div style="background: #FFFFFF; border-radius: 16px; overflow: hidden; border: 1px solid #E2E0D4; width: 100%; display: flex; flex-direction: column; min-height: 500px;">
          <img 
            src="/images/tours/guangzhou-tower-canton-china-tour.webp" 
            alt="Guangzhou Tower" 
            loading="lazy"
            style="width: 100%; height: 160px; object-fit: cover; display: block;">
          <div style="padding: 1.2rem; flex: 1; display: flex; flex-direction: column;">
            <h3 style="margin: 0 0 0.3rem 0;">Guangzhou & Macau City Break</h3>
            <p style="margin: 0 0 0.3rem 0; font-size: 0.9rem; color: #5a6b5a;">5-7 days · Guangzhou → Macau</p>
            <p style="margin: 0 0 1rem 0; font-size: 0.9rem; flex: 1;">Cantonese food, colonial history, and neon lights. Dim sum halls and the ferry to Macau.</p>
            <div style="margin-top: 0.8rem;">
              <span style="display: inline-block; background-color: #2D6A4F; color: white; padding: 0.3rem 1rem; border-radius: 20px; font-size: 0.85rem;">View tour →</span>
            </div>
          </div>
        </div>
      </a>
      
    </div>
    
    <!-- 定制区 -->
    <div style="background: #2D6A4F; border-radius: 16px; padding: 2.5rem; text-align: center; color: white;">
      <h2 style="margin: 0 0 0.5rem 0; font-size: 1.8rem; color: white;">Your trip, your way.</h2>
      <p style="margin: 0 0 1rem 0; font-size: 1rem; color: #F5F0E3; opacity: 0.95;">Tell us your dates, interests, and budget. We'll help you build a custom itinerary.</p>
      <a href="https://www.trip.com/webapp/tripmap/tripplanner?source=seo_H5_homepage&Allianceid=5609710&SID=130343298&trip_sub1=&trip_sub3=D18508961" target="_blank" rel="noopener noreferrer" style="background-color: #FFD700; color: #1F2A2E; padding: 0.8rem 2.5rem; border-radius: 30px; text-decoration: none; font-size: 1.1rem; font-weight: 600; display: inline-block;">Plan with AI →</a>
      <p style="margin: 0.5rem 0 0 0; font-size: 0.85rem; color: #F5F0E3; opacity: 0.7;">Free to use. No obligation to book.</p>
    </div>
    

</Layout>