    const option = document.createElement('option');
    option.value = country.code;
    option.textContent = country.name;
    selectEl.appendChild(option);
  });

  selectEl.addEventListener('change', (e) => {
    const code = e.target.value;
    if (!code) {
      resultDiv.style.display = 'none';
      return;
    }
    const text = visaData[code];
    if (text) {
      resultDiv.innerHTML = `<strong>${text.replace(/\n/g, '<br>')}</strong>`;
    } else {
      resultDiv.innerHTML = '<strong>📋 Visa Required</strong><br>Tourist visa required before travel. Please check the official site for details.';
    }
    resultDiv.style.display = 'block';
