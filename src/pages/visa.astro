---
import Layout from "../layouts/Layout.astro";
---

<Layout 
  title="China Visa Check · Do I Need a Visa?" 
  description="Check if you need a visa for China. Free tool — select your country and get instant visa info."
>
    <a href="/" style="display: inline-block; margin-bottom: 2rem;">← Back to Home</a>
    
    <h1>Do I need a visa?</h1>
    <p style="font-size: 1.2rem; margin-bottom: 2rem;">Check your country in 5 seconds.</p>
    
    <select id="country-select" style="width: 100%; padding: 0.75rem; margin-bottom: 1rem;">
      <option value="">-- Select your country --</option>
    </select>
    <div id="visa-result" style="padding: 1rem; background: #f5f5f5; border-radius: 8px; margin-bottom: 1rem;"></div>
    <p style="font-size: 0.85rem; color: #6c757d; margin-top: 0.5rem;"> Policy subject to change. Double-check before booking.</p>
    <a href="https://www.visaforchina.cn" target="_blank" rel="noopener noreferrer">Official visa application site →</a>

  </div>
</Layout>

