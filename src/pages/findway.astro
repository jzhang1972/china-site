---
import Layout from "../layouts/Layout.astro";
---

<Layout 
  title="China Travel Routes · Find Your Way" 
  description="Explore China by theme — tech, nature, culture, food, outdoor, slow, family. Find your perfect route."
>
  <div style="max-width: 1200px; margin: 0 auto; padding: 2rem 1.5rem;">
    
    <h1>Where to go?</h1>
    <p style="font-size: 1.2rem; margin-bottom: 2rem;">A path that shows you China and a different you.</p>
    
    <!-- 主题部分 -->
    <h2>By Theme</h2>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; margin-bottom: 3rem;">
      
      <!-- Tech -->
      <div class="card-item" style="overflow: hidden; padding: 0;">
        <img src="/images/findway/findway-tech-shanghai-pudong-skyscraper-night-skyline-china.webp" alt="Shanghai Pudong skyline at night" style="width: 100%; height: 160px; object-fit: cover; display: block;">
        <div style="padding: 1.2rem;">
          <h3 style="margin: 0 0 0.3rem 0;">Tech</h3>
          <p style="margin: 0 0 0.5rem 0;"><em>"The future isn't coming. It's already here."</em></p>
          <p style="margin: 0 0 0.8rem 0; font-size: 0.9rem; color: #5a6b5a;">Visit drone light shows, AI factories, and robot restaurants.</p>
          <a href="/theme/tech" style="color: #2D6A4F;">Explore tech routes →</a>
        </div>
      </div>
      
      <!-- Nature -->
      <div class="card-item" style="overflow: hidden; padding: 0;">
        <img src="/images/findway/findway-nature-zhangjiajie-avatar-mountains-mist-forest-hunan.webp" alt="Zhangjiajie Avatar mountains in mist" style="width: 100%; height: 160px; object-fit: cover; display: block;">
        <div style="padding: 1.2rem;">
          <h3 style="margin: 0 0 0.3rem 0;">Nature</h3>
          <p style="margin: 0 0 0.5rem 0;"><em>"No CGI. This is real."</em></p>
          <p style="margin: 0 0 0.8rem 0; font-size: 0.9rem; color: #5a6b5a;">Hike through floating mountains, kayak emerald rivers.</p>
          <a href="/theme/nature" style="color: #2D6A4F;">Explore nature routes →</a>
        </div>
      </div>
      
      <!-- Culture -->
      <div class="card-item" style="overflow: hidden; padding: 0;">
        <img src="/images/findway/findway-culture-beijing-forbidden-city-imperial-palace-golden-roof.webp" alt="Forbidden City Beijing golden roof" style="width: 100%; height: 160px; object-fit: cover; display: block;">
        <div style="padding: 1.2rem;">
          <h3 style="margin: 0 0 0.3rem 0;">Culture</h3>
          <p style="margin: 0 0 0.5rem 0;"><em>"5,000 years old. And still alive."</em></p>
          <p style="margin: 0 0 0.8rem 0; font-size: 0.9rem; color: #5a6b5a;">Walk ancient towns, learn calligraphy, wear Hanfu.</p>
          <a href="/theme/culture" style="color: #2D6A4F;">Explore culture routes →</a>
        </div>
      </div>
      
      <!-- Food -->
      <div class="card-item" style="overflow: hidden; padding: 0;">
        <img src="/images/findway/findway-food-chengdu-sichuan-hotpot-spicy-dinner-table.webp" alt="Sichuan hotpot in Chengdu" style="width: 100%; height: 160px; object-fit: cover; display: block;">
        <div style="padding: 1.2rem;">
          <h3 style="margin: 0 0 0.3rem 0;">Food</h3>
          <p style="margin: 0 0 0.5rem 0;"><em>"There's more than fried rice."</em></p>
          <p style="margin: 0 0 0.8rem 0; font-size: 0.9rem; color: #5a6b5a;">From street stalls to Michelin-starred hotpot.</p>
          <a href="/theme/food" style="color: #2D6A4F;">Explore food routes →</a>
        </div>
      </div>
      
      <!-- Outdoor -->
      <div class="card-item" style="overflow: hidden; padding: 0;">
        <img src="/images/findway/findway-outdoor-yangshuo-guilin-karst-climbing-sunset-rock.webp" alt="Rock climbing in Yangshuo karst mountains" style="width: 100%; height: 160px; object-fit: cover; display: block;">
        <div style="padding: 1.2rem;">
          <h3 style="margin: 0 0 0.3rem 0;">Outdoor</h3>
          <p style="margin: 0 0 0.5rem 0;"><em>"No ceiling. No walls. Just you and nature."</em></p>
          <p style="margin: 0 0 0.8rem 0; font-size: 0.9rem; color: #5a6b5a;">Rock climbing, white-water rafting, bamboo forest trekking.</p>
          <a href="/theme/outdoor" style="color: #2D6A4F;">Explore outdoor routes →</a>
        </div>
      </div>
      
      <!-- Slow Travel -->
      <div class="card-item" style="overflow: hidden; padding: 0;">
        <img src="/images/findway/findway-slow-dali-yunnan-old-town-erhai-lake-cafe-morning.webp" alt="Dali old town morning in Yunnan" style="width: 100%; height: 160px; object-fit: cover; display: block;">
        <div style="padding: 1.2rem;">
          <h3 style="margin: 0 0 0.3rem 0;">Slow Travel</h3>
          <p style="margin: 0 0 0.5rem 0;"><em>"Less rush. More China."</em></p>
          <p style="margin: 0 0 0.8rem 0; font-size: 0.9rem; color: #5a6b5a;">Stay in local homestays, practice tai chi at sunrise.</p>
          <a href="/theme/slow" style="color: #2D6A4F;">Explore slow travel routes →</a>
        </div>
      </div>
      
      <!-- Family -->
      <div class="card-item" style="overflow: hidden; padding: 0;">
        <img src="/images/findway/findway-family-chengdu-panda-base-bamboo-feeding-cute-china.webp" alt="Giant panda eating bamboo in Chengdu" style="width: 100%; height: 160px; object-fit: cover; display: block;">
        <div style="padding: 1.2rem;">
          <h3 style="margin: 0 0 0.3rem 0;">Family</h3>
          <p style="margin: 0 0 0.5rem 0;"><em>"No one gets bored. Seriously."</em></p>
          <p style="margin: 0 0 0.8rem 0; font-size: 0.9rem; color: #5a6b5a;">Panda hugs, theme parks, and kid-friendly museums.</p>
          <a href="/theme/family" style="color: #2D6A4F;">Explore family routes →</a>
        </div>
      </div>
      
    </div>

    <!-- AI Planner 板块 -->
    <div style="background-color: #F5F3EE; padding: 2rem 1.5rem; border-radius: 20px; text-align: center; margin-top: 2rem;">
      <h2 style="font-size: 1.4rem; font-weight: 600; color: #1F2A2E; margin: 0 0 0.5rem 0;">Not sure where to start? Let experts help you.</h2>
      <a href="/tours" style="display: inline-block; background-color: #FFD700; color: #1F2A2E; padding: 0.6rem 2rem; border-radius: 30px; text-decoration: none; font-weight: 600; font-size: 1rem; transition: background-color 0.2s;">Popular tours →</a>
    </div>

  </div>
</Layout>

<style is:global>
  body {
    background: #F8F6F0;
  }
  
  .card-item {
    background: #FFFFFF;
    border-radius: 16px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  
  .card-item:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 28px rgba(0,0,0,0.10);
  }
</style>