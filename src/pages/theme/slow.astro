---
import Layout from "../../layouts/Layout.astro";
---

<Layout 
  title="Slow Travel China · Water Towns & Tea" 
  description="Suzhou gardens, Hangzhou's West Lake, Wuzhen canals. Slow down and discover Jiangnan's water towns."
>


    <!-- 返回链接 -->
    <a href="/findway" style="display: inline-flex; align-items: center; gap: 0.5rem; margin-bottom: 2rem; color: #6c757d; text-decoration: none; font-size: 0.9rem; transition: color 0.3s;">
      <span>←</span> Back to Themes
    </a>
    
    <!-- ===== 主题标题 ===== -->
    <div style="text-align: center; margin-bottom: 2.5rem;">
      <span style="display: inline-block; background: rgba(196, 158, 58, 0.12); color: #C49E3A; padding: 0.15rem 1rem; border-radius: 20px; font-size: 0.7rem; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 0.75rem;">Theme</span>
      <h1 style="font-size: 3.5rem; font-weight: 700; color: #1F2A2E; margin: 0 0 0.3rem 0; letter-spacing: -1px;">Slow Travel</h1>
      <p style="font-size: 1.2rem; font-style: italic; color: #6c757d; margin-bottom: 0;">"Less rush. More China."</p>
    </div>
    
    <!-- ===== 轮播图 ===== -->
<div id="slow-carousel" style="position: relative; overflow: hidden; border-radius: 20px; margin-bottom: 3rem; background: #e8e4dc; box-shadow: 0 4px 24px rgba(0,0,0,0.06);">
  <div id="slow-carousel-track" style="display: flex; transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);">
    
    <!-- 图片1：苏州园林 -->
    <div class="slow-slide" style="min-width: 100%; position: relative;">
      <img src="/images/theme/slow/slow-suzhou-classical-garden-pavilion-china.webp" alt="Classical Chinese garden with pavilion and pond in Suzhou, China" 

loading="eager"

style="width: 100%; height: 420px; object-fit: cover; display: block;">
      <div style="position: absolute; bottom: 0; left: 0; right: 0; padding: 2rem; background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, transparent 100%);">
        <p style="color: rgba(255,255,255,0.85); font-size: 0.95rem; margin: 0; font-weight: 300;">Suzhou — where gardens are poetry written in stone and water</p>
      </div>
    </div>
    
    <!-- 图片2：杭州西湖 -->
    <div class="slow-slide" style="min-width: 100%; position: relative;">
      <img src="/images/theme/slow/slow-hangzhou-west-lake-sunset-china.webp" alt="West Lake at sunset with pagoda and mountains in Hangzhou, China" 

loading="eager"

style="width: 100%; height: 420px; object-fit: cover; display: block;">
      <div style="position: absolute; bottom: 0; left: 0; right: 0; padding: 2rem; background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, transparent 100%);">
        <p style="color: rgba(255,255,255,0.85); font-size: 0.95rem; margin: 0; font-weight: 300;">Hangzhou — a thousand years of poetry, still written on the lake</p>
      </div>
    </div>
    
    <!-- 图片3：乌镇水乡 -->
    <div class="slow-slide" style="min-width: 100%; position: relative;">
      <img src="/images/theme/slow/slow-wuzhen-water-town-canal-boat-china.webp" alt="Ancient water town with wooden houses and canal boats in Wuzhen, China" 

loading="eager"

style="width: 100%; height: 420px; object-fit: cover; display: block;">
      <div style="position: absolute; bottom: 0; left: 0; right: 0; padding: 2rem; background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, transparent 100%);">
        <p style="color: rgba(255,255,255,0.85); font-size: 0.95rem; margin: 0; font-weight: 300;">Wuzhen — life still moves at the pace of a wooden boat</p>
      </div>
    </div>
    
    <!-- 图片4：龙井茶园 -->
    <div class="slow-slide" style="min-width: 100%; position: relative;">
      <img src="/images/theme/slow/slow-hangzhou-longjing-tea-terraces-china.webp" alt="Terraced tea plantations on the hills of Longjing, Hangzhou, China" 

loading="eager"

style="width: 100%; height: 420px; object-fit: cover; display: block;">
      <div style="position: absolute; bottom: 0; left: 0; right: 0; padding: 2rem; background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, transparent 100%);">
        <p style="color: rgba(255,255,255,0.85); font-size: 0.95rem; margin: 0; font-weight: 300;">Longjing — where the best tea in China grows among the mist</p>
      </div>
    </div>
    
  </div>
  
  <!-- 箭头 -->
  <button id="slow-prev" style="position: absolute; top: 50%; left: 16px; transform: translateY(-50%); background: rgba(255,255,255,0.85); backdrop-filter: blur(4px); color: #1F2A2E; border: none; width: 40px; height: 40px; border-radius: 50%; font-size: 1.3rem; cursor: pointer; z-index: 10; display: flex; align-items: center; justify-content: center; box-shadow: 0 2px 12px rgba(0,0,0,0.08); transition: all 0.3s;">‹</button>
  <button id="slow-next" style="position: absolute; top: 50%; right: 16px; transform: translateY(-50%); background: rgba(255,255,255,0.85); backdrop-filter: blur(4px); color: #1F2A2E; border: none; width: 40px; height: 40px; border-radius: 50%; font-size: 1.3rem; cursor: pointer; z-index: 10; display: flex; align-items: center; justify-content: center; box-shadow: 0 2px 12px rgba(0,0,0,0.08); transition: all 0.3s;">›</button>
  
  <!-- 圆点 -->
  <div id="slow-dots" style="position: absolute; bottom: 64px; left: 0; right: 0; display: flex; justify-content: center; gap: 10px; z-index: 10;">
    <span class="slow-dot active" data-index="0" style="width: 10px; height: 10px; border-radius: 50%; background: #FFD700; cursor: pointer; transition: all 0.3s;"></span>
    <span class="slow-dot" data-index="1" style="width: 10px; height: 10px; border-radius: 50%; background: rgba(255,255,255,0.4); cursor: pointer; transition: all 0.3s;"></span>
    <span class="slow-dot" data-index="2" style="width: 10px; height: 10px; border-radius: 50%; background: rgba(255,255,255,0.4); cursor: pointer; transition: all 0.3s;"></span>
    <span class="slow-dot" data-index="3" style="width: 10px; height: 10px; border-radius: 50%; background: rgba(255,255,255,0.4); cursor: pointer; transition: all 0.3s;"></span>
  </div>
</div>

<!-- Lightbox -->
<div id="slow-lightbox" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.88); z-index: 1000; align-items: center; justify-content: center; cursor: pointer; backdrop-filter: blur(4px);">
  <img id="slow-lightbox-img" src="" alt="Enlarged view" style="max-width: 90%; max-height: 80%; object-fit: contain; border-radius: 12px; box-shadow: 0 30px 80px rgba(0,0,0,0.6);">
  <p id="slow-lightbox-caption" style="position: absolute; bottom: 60px; left: 50%; transform: translateX(-50%); color: rgba(255,255,255,0.85); font-size: 0.95rem; background: rgba(0,0,0,0.5); backdrop-filter: blur(8px); padding: 0.4rem 1.5rem; border-radius: 30px; margin: 0; text-align: center; max-width: 80%;"></p>
  <button id="slow-lightbox-close" style="position: absolute; top: 24px; right: 32px; background: none; border: none; color: #fff; font-size: 2.5rem; cursor: pointer; opacity: 0.5; transition: opacity 0.3s;">&times;</button>
</div>
    
    <!-- 简介 -->
