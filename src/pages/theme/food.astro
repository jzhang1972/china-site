        <span class="food-dot active" data-index="0" style="width: 8px; height: 8px; border-radius: 50%; background: #FFD700; cursor: pointer; transition: all 0.3s;"></span>
        <span class="food-dot" data-index="1" style="width: 8px; height: 8px; border-radius: 50%; background: rgba(255,255,255,0.4); cursor: pointer; transition: all 0.3s;"></span>
        <span class="food-dot" data-index="2" style="width: 8px; height: 8px; border-radius: 50%; background: rgba(255,255,255,0.4); cursor: pointer; transition: all 0.3s;"></span>
        <span class="food-dot" data-index="3" style="width: 8px; height: 8px; border-radius: 50%; background: rgba(255,255,255,0.4); cursor: pointer; transition: all 0.3s;"></span>
      </div>
    </div>

    <!-- Lightbox -->
    <div id="food-lightbox" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.88); z-index: 1000; align-items: center; justify-content: center; cursor: pointer; backdrop-filter: blur(4px);">
      <img id="food-lightbox-img" src="" alt="Enlarged view" style="max-width: 90%; max-height: 80%; object-fit: contain; border-radius: 12px; box-shadow: 0 30px 80px rgba(0,0,0,0.6);">
      <p id="food-lightbox-caption" style="position: absolute; bottom: 60px; left: 50%; transform: translateX(-50%); color: rgba(255,255,255,0.8); font-size: 0.9rem; background: rgba(0,0,0,0.5); backdrop-filter: blur(8px); padding: 0.4rem 1.5rem; border-radius: 30px; margin: 0; text-align: center; max-width: 80%;"></p>
      <button id="food-lightbox-close" style="position: absolute; top: 24px; right: 32px; background: none; border: none; color: #fff; font-size: 2.5rem; cursor: pointer; opacity: 0.5; transition: opacity 0.3s;">&times;</button>
    </div>

    <!-- ===== RECOMMENDED CITIES ===== -->
    <div style="margin-bottom: 1.5rem;">
      <span style="display: inline-block; background: #2D6A4F; color: #FFFFFF; font-size: 0.8rem; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; padding: 0.3rem 1.2rem; border-radius: 4px;">RECOMMENDED CITIES</span>
    </div>
    <div style="display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.75rem; margin-bottom: 3rem;">
      <span style="background: #EDEAE0; color: #1F2A2E; padding: 0.3rem 1rem; border-radius: 20px; font-size: 0.85rem;">Chengdu</span>
      <span style="background: #EDEAE0; color: #1F2A2E; padding: 0.3rem 1rem; border-radius: 20px; font-size: 0.85rem;">Chongqing</span>
      <span style="background: #EDEAE0; color: #1F2A2E; padding: 0.3rem 1rem; border-radius: 20px; font-size: 0.85rem;">Xi'an</span>
      <span style="background: #EDEAE0; color: #1F2A2E; padding: 0.3rem 1rem; border-radius: 20px; font-size: 0.85rem;">Guangzhou</span>
      <span style="background: #EDEAE0; color: #1F2A2E; padding: 0.3rem 1rem; border-radius: 20px; font-size: 0.85rem;">Changsha</span>
      <span style="background: #EDEAE0; color: #1F2A2E; padding: 0.3rem 1rem; border-radius: 20px; font-size: 0.85rem;">Shanghai</span>
    </div>

    <div style="height: 0.5rem;"></div>

    <!-- ===== FEATURED ROUTE ===== -->
    <div style="margin-bottom: 1.5rem;">
      <span style="display: inline-block; background: #2D6A4F; color: #FFFFFF; font-size: 0.8rem; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; padding: 0.3rem 1.2rem; border-radius: 4px;">FEATURED ROUTE</span>
    </div>

    <!-- ===== 路线标题区 ===== -->
    <div style="margin-bottom: 2rem;">
      <h2 style="font-size: 2.4rem; font-weight: 700; color: #1F2A2E; margin: 0 0 0.3rem 0; letter-spacing: -0.5px;">
        Noodles · Hotpot · <span style="color: #C49E3A;">Dim Sum</span>
      </h2>
      <div style="display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap;">
        <p style="font-size: 1.05rem; color: #6c757d; font-style: italic; margin: 0;">China's flavors, north to south</p>
        <span style="background: rgba(196, 158, 58, 0.1); color: #C49E3A; padding: 0.15rem 0.8rem; border-radius: 20px; font-size: 0.75rem; border: 1px solid rgba(196, 158, 58, 0.15);">Xi'an → Chengdu → Guangzhou · 14–18 days</span>
      </div>
    </div>
    
    <!-- 简介 -->
    <p style="color: #4a4a4a; line-height: 1.9; font-size: 1.05rem; max-width: 750px; margin-bottom: 2.5rem; border-left: 3px solid #C49E3A; padding-left: 1.5rem;">
      From the noodles of Xi'an to the hotpot of Chengdu to the dim sum of Guangzhou. Your taste buds will thank you.
    </p>
    
    <!-- ===== 三城 Things to do ===== -->
    <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1.5rem; margin-bottom: 2.5rem;">
      
      <!-- 西安 -->
      <div style="background: #FFFFFF; border-radius: 16px; padding: 1.5rem; box-shadow: 0 2px 16px rgba(0,0,0,0.04);">
        <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1.25rem;">
          <h3 style="color: #1F2A2E; font-size: 1.1rem; margin: 0; font-weight: 600;">Xi'an</h3>
          <span style="margin-left: auto; background: #EDEAE0; color: #6c757d; padding: 0.1rem 0.6rem; border-radius: 12px; font-size: 0.65rem; font-weight: 500;">5 spots</span>
        </div>
        <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.75rem;">
          <li style="display: flex; gap: 0.75rem; align-items: flex-start; color: #4a4a4a; font-size: 0.9rem; line-height: 1.5;">
            <span style="color: #C49E3A; font-size: 0.8rem; margin-top: 0.1rem; flex-shrink: 0;">▸</span>
            <div>
              <a href="https://www.google.com/maps/search/?api=1&query=Muslim+Quarter+Xi'an" 
                 target="_blank" 
                 rel="noopener noreferrer" 
                 style="color: #C49E3A; font-weight: 600; text-decoration: none; border-bottom: 1px solid transparent; transition: border-color 0.2s, color 0.2s;">
                 Muslim Quarter food crawl
              </a>
              — Lamb skewers, persimmon cakes, and the best roujiamo in town.
            </div>
          </li>
          <li style="display: flex; gap: 0.75rem; align-items: flex-start; color: #4a4a4a; font-size: 0.9rem; line-height: 1.5;">
            <span style="color: #C49E3A; font-size: 0.8rem; margin-top: 0.1rem; flex-shrink: 0;">▸</span>
            <div>
              <a href="https://www.google.com/maps/place/Biangbiang%E9%9D%A2/@34.2634014,108.9582291,17z/data=!3m1!4b1!4m6!3m5!1s0x36637af28a8720e9:0x1b087fa6430cf54a!8m2!3d34.263397!4d108.960804!16s%2Fg%2F1tn4wcxq?entry=ttu&g_ep=EgoyMDI2MDcwOC4wIKXMDSoASAFQAw%3D%3D" 
                 target="_blank" 
                 rel="noopener noreferrer" 
                 style="color: #C49E3A; font-weight: 600; text-decoration: none; border-bottom: 1px solid transparent; transition: border-color 0.2s, color 0.2s;">
                 Biangbiang noodles
              </a>
              — Thick, hand-pulled noodles tossed in chili oil and garlic.
            </div>
          </li>
