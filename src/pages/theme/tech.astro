---
import Layout from "../../layouts/Layout.astro";
---

<Layout 
  title="Tech in China · Futuristic Travel Guide" 
  description="From neon Chongqing to Shenzhen's tech hubs. Discover China's most futuristic cities — high-speed rail, AI, and digital everything."
>
  <!-- 原有内容 -->

  <!-- 返回链接 -->
    <a href="/findway" style="display: inline-flex; align-items: center; gap: 0.5rem; margin-bottom: 2rem; color: #6c757d; text-decoration: none; font-size: 0.9rem; transition: color 0.3s;">
      <span>←</span> Back to Themes
    </a>

    <!-- ===== 主题标题 ===== -->
    <div style="text-align: center; margin-bottom: 2.5rem;">
<span style="display: inline-block; background: rgba(196, 158, 58, 0.12); color: #C49E3A; padding: 0.15rem 1rem; border-radius: 20px; font-size: 0.7rem; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 0.75rem;">Theme</span>
      <h1 style="font-size: 3.5rem; font-weight: 700; color: #1F2A2E; margin: 0 0 0.3rem 0; letter-spacing: -1px;">Tech</h1>
      <p style="font-size: 1.2rem; font-style: italic; color: #6c757d; margin-bottom: 0;">"The future isn't coming. It's already here."</p>
    </div>
    
<!-- ===== 轮播图 ===== -->
<div id="tech-carousel" style="position: relative; overflow: hidden; border-radius: 20px; margin-bottom: 3rem; background: #e8e4dc; box-shadow: 0 4px 24px rgba(0,0,0,0.06);">
  <div id="tech-carousel-track" style="display: flex; transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);">
    
    <!-- 图片1：重庆洪崖洞 -->
    <div class="tech-slide" style="min-width: 100%; position: relative;">
      <img src="/images/theme/tech/tech-chongqing-hongyadong-night-cyberpunk-china.webp" alt="Hongyadong stilt houses lit up at night in Chongqing, China" 

loading="eager"

style="width: 100%; height: 420px; object-fit: cover; display: block;">
      <div style="position: absolute; bottom: 0; left: 0; right: 0; padding: 2rem; background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, transparent 100%);">
        <p style="color: rgba(255,255,255,0.85); font-size: 0.95rem; margin: 0; font-weight: 300;">Hongyadong — a 2,000-year-old stilt house complex glowing in neon</p>
      </div>
    </div>
    
    <!-- 图片2：重庆单轨穿楼 -->
    <div class="tech-slide" style="min-width: 100%; position: relative;">
      <img src="/images/theme/tech/tech-chongqing-monorail-through-building-china.webp" alt="Monorail passing through a residential building in Chongqing, China" 

loading="eager"

style="width: 100%; height: 420px; object-fit: cover; display: block;">
      <div style="position: absolute; bottom: 0; left: 0; right: 0; padding: 2rem; background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, transparent 100%);">
        <p style="color: rgba(255,255,255,0.85); font-size: 0.95rem; margin: 0; font-weight: 300;">Liziba Station — monorail punching straight through a residential tower</p>
      </div>
    </div>
    
    <!-- 图片3：深圳湾 -->
    <div class="tech-slide" style="min-width: 100%; position: relative;">
      <img src="/images/theme/tech/tech-shenzhen-bay-skyline-night-china.webp" alt="Shenzhen Bay skyline at night with futuristic city lights, China" 

loading="eager"

style="width: 100%; height: 420px; object-fit: cover; display: block;">
      <div style="position: absolute; bottom: 0; left: 0; right: 0; padding: 2rem; background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, transparent 100%);">
        <p style="color: rgba(255,255,255,0.85); font-size: 0.95rem; margin: 0; font-weight: 300;">Shenzhen Bay — where the future meets the sea</p>
      </div>
    </div>
    
    <!-- 图片4：腾讯总部 -->
    <div class="tech-slide" style="min-width: 100%; position: relative;">
      <img src="/images/theme/tech/tech-shenzhen-tencent-headquarters-night-china.webp" alt="Tencent headquarters building illuminated at night in Shenzhen, China" 

loading="eager"

style="width: 100%; height: 420px; object-fit: cover; display: block;">
      <div style="position: absolute; bottom: 0; left: 0; right: 0; padding: 2rem; background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, transparent 100%);">
        <p style="color: rgba(255,255,255,0.85); font-size: 0.95rem; margin: 0; font-weight: 300;">Tencent headquarters — China's tech giant, lit up after dark</p>
      </div>
    </div>
    
  </div>
  
  <!-- 箭头 -->
  <button id="tech-prev" style="position: absolute; top: 50%; left: 16px; transform: translateY(-50%); background: rgba(255,255,255,0.85); backdrop-filter: blur(4px); color: #1F2A2E; border: none; width: 40px; height: 40px; border-radius: 50%; font-size: 1.3rem; cursor: pointer; z-index: 10; display: flex; align-items: center; justify-content: center; box-shadow: 0 2px 12px rgba(0,0,0,0.08); transition: all 0.3s;">‹</button>
  <button id="tech-next" style="position: absolute; top: 50%; right: 16px; transform: translateY(-50%); background: rgba(255,255,255,0.85); backdrop-filter: blur(4px); color: #1F2A2E; border: none; width: 40px; height: 40px; border-radius: 50%; font-size: 1.3rem; cursor: pointer; z-index: 10; display: flex; align-items: center; justify-content: center; box-shadow: 0 2px 12px rgba(0,0,0,0.08); transition: all 0.3s;">›</button>
  
  <!-- 圆点 -->
  <div id="tech-dots" style="position: absolute; bottom: 64px; left: 0; right: 0; display: flex; justify-content: center; gap: 10px; z-index: 10;">
    <span class="tech-dot active" data-index="0" style="width: 10px; height: 10px; border-radius: 50%; background: #FFD700; cursor: pointer; transition: all 0.3s;"></span>
    <span class="tech-dot" data-index="1" style="width: 10px; height: 10px; border-radius: 50%; background: rgba(255,255,255,0.4); cursor: pointer; transition: all 0.3s;"></span>
    <span class="tech-dot" data-index="2" style="width: 10px; height: 10px; border-radius: 50%; background: rgba(255,255,255,0.4); cursor: pointer; transition: all 0.3s;"></span>
    <span class="tech-dot" data-index="3" style="width: 10px; height: 10px; border-radius: 50%; background: rgba(255,255,255,0.4); cursor: pointer; transition: all 0.3s;"></span>
  </div>
</div>

<!-- Lightbox -->
<div id="tech-lightbox" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.88); z-index: 1000; align-items: center; justify-content: center; cursor: pointer; backdrop-filter: blur(4px);">
