---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const props = Astro.props as Props;

const pageTitle =
  typeof props.title === "string" ? props.title.trim() : "";

const pageDescription =
  typeof props.description === "string"
    ? props.description.trim()
    : "";

const siteTitle = pageTitle
  ? `${pageTitle} · YOGOTOCHINA`
  : "YOGOTOCHINA · China Travel Guide";

const siteDescription =
  pageDescription ||
  "Plan your China trip with ease. Visa info, travel guides, routes, real stories, and trusted tours.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />

    <meta
      name="viewport"
      content="width=device-width, initial-scale=1"
    />

    <title>{siteTitle}</title>

    <meta
      name="description"
      content={siteDescription}
    />

    <meta
      property="og:title"
      content={siteTitle}
    />

    <meta
      property="og:description"
      content={siteDescription}
    />

    <meta
      property="og:type"
      content="website"
    />

    <meta
      property="og:url"
      content={Astro.url.href}
    />

    <meta
      property="og:image"
      content="https://yogotochina.com/og-image.jpg"
    />

    <meta
      property="og:image:width"
      content="1200"
    />

    <meta
      property="og:image:height"
      content="630"
    />

    <meta
      name="twitter:card"
      content="summary_large_image"
    />

    <meta
      name="twitter:title"
      content={siteTitle}
    />

    <meta
      name="twitter:description"
      content={siteDescription}
    />

    <meta
      name="twitter:image"
      content="https://yogotochina.com/og-image.jpg"
    />

    <link
      rel="canonical"
      href={Astro.url.href}
    />

    <link
      rel="icon"
      type="image/png"
      href="/favicon.png"
    />

    <!-- 预加载首页主要图片 -->
    <link
      rel="preload"
      as="image"
      href="/images/hero/tech-chongqing-hongyadong-night-stilt-houses-river-china.webp"
      fetchpriority="high"
    />

    <link
      rel="preconnect"
      href="https://fonts.googleapis.com"
    />

    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin
    />

    <link
      href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&display=swap"
      rel="stylesheet"
    />

    <!--
      GTranslate 设置 - 使用 dropdown.js（纯文字语言名称，无国旗）
      
      共 15 种语言（已移除 繁體中文）：
      1. English
      2. हिन्दी
      3. Español
      4. Bahasa Indonesia
      5. العربية
      6. Português
      7. Русский
      8. 日本語
      9. Français
      10. Deutsch
      11. Italiano
      12. 한국어
      13. Tiếng Việt
      14. ไทย
      15. Nederlands
      
      关键配置：
      - 使用 dropdown.js 而非 globe.js
      - native_language_names: true 用本国语显示
      - CSS 隐藏所有国旗
    -->
    <script is:inline>
      window.gtranslateSettings = {
        default_language: "en",


languages: [
  // ===== 英语 + 欧洲主要市场 =====
  "en",     // 1. English（核心语言）
  "de",     // 2. Deutsch（德国）
  "fr",     // 3. Français（法国）
  "es",     // 4. Español（西班牙）
  "it",     // 5. Italiano（意大利）
  
  // ===== 中文市场 =====
  "zh-TW",  // 6. 繁體中文（台湾/香港/澳门）
  "zh-CN",  // 7. 简体中文（中国大陆/新加坡）
  
  // ===== 亚洲（日韩） =====
  "ja",     // 8. 日本語
  "ko",     // 9. 한국어
  
  // ===== 欧洲其他 =====
  "nl",     // 10. Nederlands（荷兰）
  "pt",     // 11. Português（葡萄牙/巴西）
  
  // ===== 东南亚 =====
  "id",     // 12. Bahasa Indonesia
  "ms",     // 13. Bahasa Malaysia
  "vi",     // 14. Tiếng Việt
  "th",     // 15. ไทย
  
  // ===== 南亚（人口大国） =====
  "hi",     // 16. हिन्दी（印度）
  "bn",     // 17. বাংলা（孟加拉）
  "ur",     // 18. اردو（巴基斯坦）
  
  // ===== 中东 + 俄罗斯 =====
  "ar",     // 19. العربية
  "ru",     // 20. Русский
  
  // ===== 北欧 =====
  "da",     // 21. Dansk
  "no",     // 22. Norsk
  "sv",     // 23. Svenska
  "fi"      // 24. Suomi
],

       wrapper_selector: ".gtranslate_wrapper",
        native_language_names: true,
        detect_browser_language: false,
      };
    </script>

    <!-- 
      使用 dropdown.js 而非 globe.js
      dropdown.js 更容易控制显示样式
    -->
    <script
      is:inline
      defer
      src="https://cdn.gtranslate.net/widgets/latest/dropdown.js"
    ></script>

    <style is:global>
      /* ========================================
         全局设置
         ======================================== */

      * {
        box-sizing: border-box;
      }

      html {
        min-height: 100%;
      }

      body {
        min-height: 100%;
        margin: 0;
        font-family: "Inter", sans-serif;
        color: #1f2a2e;
        background: #f8f6f0;
      }

      body.menu-open {
        overflow: hidden;
      }

      a {
        text-decoration: none;
      }

      img {
        display: block;
        max-width: 100%;
        height: auto;
      }

      button,
      select {
        font: inherit;
      }

      /* ========================================
         导航栏
         ======================================== */

      .navbar {
        position: relative;
        z-index: 1000;
        padding: 0.75rem 1rem;
        background-color: #ffffff;
        border-bottom: 1px solid #edeae0;
      }

      .nav-container {
        display: flex;
        align-items: center;
        justify-content: space-between;
        width: 100%;
        max-width: 1200px;
        min-height: 44px;
        margin: 0 auto;
      }

      .logo {
        flex: 0 0 auto;
      }

      .logo a {
        display: block;
      }

      .logo img {
        width: auto;
        height: 40px;
      }

      .nav-right {
        display: flex;
        align-items: center;
        gap: 0.35rem;
      }

      /* ========================================
         电脑端导航菜单
         ======================================== */

      .nav-menu {
        display: flex;
        align-items: center;
        gap: 0.2rem;
        padding: 0;
        margin: 0;
        list-style: none;
      }

      .nav-menu li {
        display: flex;
        align-items: center;
      }

      .nav-menu li a {
        display: inline-flex;
        align-items: center;
        min-height: 40px;
        padding: 0.5rem 0.85rem;
        color: #1f2a2e;
        font-size: 0.92rem;
        font-weight: 500;
        white-space: nowrap;
        border-radius: 30px;
        transition:
          color 0.2s ease,
          background-color 0.2s ease;
      }

      .nav-menu li a:hover,
      .nav-menu li a:focus-visible {
        color: #1f2a2e;
        background: #f0ede5;
        outline: none;
      }

      /* ========================================
         翻译按钮 - 纯文字下拉菜单
         使用 dropdown.js，CSS 隐藏所有国旗
         ======================================== */

      .gtranslate_wrapper {
        position: relative;
        z-index: 1100;
        display: inline-block;
        padding: 0 12px;
        height: 42px;
        line-height: 42px;
        cursor: pointer;
        border-radius: 30px;
        transition: background-color 0.2s ease;
        font-size: 0.85rem;
        font-weight: 500;
        color: #1f2a2e;
        background: transparent;
        user-select: none;
      }

      .gtranslate_wrapper:hover,
      .gtranslate_wrapper:focus-within {
        background: #f0ede5;
      }

      /*
        隐藏所有国旗图片
        纯文字显示
      */
      .gtranslate_wrapper img {
        display: none !important;
      }

      /*
        当前选中的语言 - 纯文字
      */
      .gtranslate_wrapper .gt-current-lang {
        display: inline !important;
      }

      .gtranslate_wrapper .gt-current-lang span {
        display: inline !important;
      }

      /*
        下拉菜单 - 纯文字
      */
      .gtranslate_wrapper .gt_options,
      .gtranslate_wrapper .gt_languages,
      .gtranslate_wrapper [class*="gt_options"] {
        position: absolute !important;
        top: calc(100% + 6px) !important;
        left: 50% !important;
        transform: translateX(-50%) !important;
        z-index: 99999 !important;
        min-width: 160px !important;
        max-height: min(70vh, 440px) !important;
        overflow-y: auto !important;
        background: #ffffff !important;
        border: 1px solid #e5e1d7 !important;
        border-radius: 12px !important;
        box-shadow: 0 14px 38px rgb(31 42 46 / 16%) !important;
        padding: 6px 0 !important;
      }

      /*
        下拉菜单选项 - 纯文字
      */
      .gtranslate_wrapper .gt_options a,
      .gtranslate_wrapper .gt_languages a {
        display: block !important;
        padding: 8px 20px !important;
        color: #1f2a2e !important;
        font-size: 0.9rem !important;
        font-weight: 400 !important;
        background: #ffffff !important;
        border: 0 !important;
        text-align: left !important;
        transition: background-color 0.15s ease !important;
        white-space: nowrap !important;
      }

      .gtranslate_wrapper .gt_options a:hover,
      .gtranslate_wrapper .gt_languages a:hover {
        background: #f0ede5 !important;
        color: #1f2a2e !important;
      }

      /*
        隐藏 GTranslate 品牌信息
      */
      .gtranslate_wrapper .gt-powered-by,
      .gtranslate_wrapper .gt_powered_by,
      .gtranslate_wrapper [class*="powered"] {
        display: none !important;
      }

      /*
        隐藏下拉菜单中的语言代码
      */
      .gtranslate_wrapper .gt_options .gt-lang-code,
      .gtranslate_wrapper .gt_languages .gt-lang-code {
        display: none !important;
      }

      /* ========================================
         汉堡菜单按钮
         ======================================== */

      .hamburger {
        display: none;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        width: 42px;
        height: 42px;
        padding: 0;
        cursor: pointer;
        background: transparent;
        border: 0;
        border-radius: 50%;
      }

      .hamburger:hover,
      .hamburger:focus-visible {
        background: #f0ede5;
        outline: none;
      }

      .hamburger .bar {
        width: 25px;
        height: 2.5px;
        margin: 2.5px 0;
        background-color: #1f2a2e;
        border-radius: 2px;
        transition:
          transform 0.3s ease,
          opacity 0.3s ease;
      }

      .hamburger.open .bar:nth-child(1) {
        transform: translateY(7.5px) rotate(45deg);
      }

      .hamburger.open .bar:nth-child(2) {
        opacity: 0;
      }

      .hamburger.open .bar:nth-child(3) {
        transform: translateY(-7.5px) rotate(-45deg);
      }

      /* ========================================
         移动端全屏菜单
         ======================================== */

      .fullscreen-menu {
        position: fixed;
        inset: 0;
        z-index: 900;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 90px 1.5rem 2rem;
        overflow-y: auto;
        visibility: hidden;
        background: #ffffff;
        opacity: 0;
        pointer-events: none;
        transition:
          opacity 0.3s ease,
          visibility 0.3s ease;
      }

      .fullscreen-menu.open {
        visibility: visible;
        opacity: 1;
        pointer-events: auto;
      }

      .fullscreen-menu ul {
        width: 100%;
        max-width: 420px;
        padding: 0;
        margin: 0;
        text-align: center;
        list-style: none;
      }

      .fullscreen-menu li {
        margin: 0.35rem 0;
      }

      .fullscreen-menu a {
        display: block;
        padding: 0.65rem 1rem;
        color: #1f2a2e;
        font-size: clamp(1.3rem, 5vw, 1.8rem);
        font-weight: 500;
        border-radius: 14px;
        transition:
          color 0.2s ease,
          background-color 0.2s ease;
      }

      .fullscreen-menu a:hover,
      .fullscreen-menu a:focus-visible {
        color: #a47b17;
        background: #f8f6f0;
        outline: none;
      }

      /* ========================================
         通用内容
         ======================================== */

      .card-item {
        overflow: hidden;
        background: #ffffff;
        border-radius: 16px;
        box-shadow: 0 2px 8px rgb(0 0 0 / 5%);
        transition:
          transform 0.25s ease,
          box-shadow 0.25s ease;
      }

      .card-item:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 28px rgb(0 0 0 / 10%);
      }

      .content img {
        max-width: 100%;
        height: auto;
      }

      #grid-start img {
        width: 100% !important;
        max-width: none !important;
        height: 100% !important;
        object-fit: cover !important;
      }

      .container {
        width: 100%;
        max-width: 1200px;
        padding: 2rem 1.5rem;
        margin: 0 auto;
      }

      /* ========================================
         页脚
         ======================================== */

      .site-footer {
        padding: 3rem 1rem 1rem;
        margin-top: 4rem;
        color: #f9f7f1;
        background-color: #1f2a2e;
      }

      .footer-grid {
        display: grid;
        grid-template-columns:
          repeat(auto-fit, minmax(180px, 1fr));
        gap: 2rem;
        width: 100%;
        max-width: 1200px;
        margin: 0 auto;
      }

      .footer-brand {
        color: #ffd700;
      }

      .footer-brand h3 {
        margin: 0 0 0.5rem;
        color: #ffd700;
      }

      .footer-description {
        color: #ffffff;
        opacity: 0.8;
      }

      .site-footer h4 {
        color: #ffd700;
      }

      .site-footer ul {
        padding: 0;
        margin: 0;
        list-style: none;
      }

      .site-footer li {
        margin-bottom: 0.55rem;
      }

      .site-footer a {
        color: #f9f7f1;
      }

      .site-footer a:hover,
      .site-footer a:focus-visible {
        text-decoration: underline;
        outline: none;
      }

      .footer-bottom {
        padding-top: 2rem;
        margin-top: 2rem;
        text-align: center;
        border-top: 1px solid rgb(255 255 255 / 10%);
      }

      .footer-bottom p {
        margin: 0;
        color: #f9f7f1;
      }

      /* ========================================
         较窄电脑屏幕
         ======================================== */

      @media (max-width: 980px) {
        .nav-menu {
          gap: 0;
        }

        .nav-menu li a {
          padding-right: 0.58rem;
          padding-left: 0.58rem;
          font-size: 0.84rem;
        }
      }

      /* ========================================
         移动端
         ======================================== */

      @media (max-width: 768px) {
        .navbar {
          padding: 0.65rem 1rem;
        }

        /*
          隐藏普通导航链接
          翻译按钮保留在 nav-right 中
        */
        .nav-menu {
          display: none;
        }

        .hamburger {
          display: flex;
        }

        /*
          移动端翻译按钮适配
        */
        .gtranslate_wrapper {
          height: 40px !important;
          line-height: 40px !important;
          padding: 0 10px !important;
          font-size: 0.78rem !important;
        }

        /*
          下拉菜单在移动端适配
        */
        .gtranslate_wrapper .gt_options,
        .gtranslate_wrapper .gt_languages,
        .gtranslate_wrapper [class*="gt_options"] {
          min-width: 150px !important;
          max-height: 50vh !important;
        }

        .gtranslate_wrapper .gt_options a,
        .gtranslate_wrapper .gt_languages a {
          padding: 8px 16px !important;
          font-size: 0.85rem !important;
        }

        .container {
          padding: 1rem;
        }
      }

      @media (max-width: 380px) {
        .navbar {
          padding-right: 0.75rem;
          padding-left: 0.75rem;
        }

        .logo img {
          width: auto;
          max-width: 165px;
          height: 36px;
          object-fit: contain;
        }

        .nav-right {
          gap: 0.1rem;
        }

        .gtranslate_wrapper {
          height: 36px !important;
          line-height: 36px !important;
          padding: 0 8px !important;
          font-size: 0.7rem !important;
        }

        .gtranslate_wrapper .gt_options a,
        .gtranslate_wrapper .gt_languages a {
          padding: 6px 14px !important;
          font-size: 0.8rem !important;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        *,
        *::before,
        *::after {
          scroll-behavior: auto !important;
          transition-duration: 0.01ms !important;
          animation-duration: 0.01ms !important;
          animation-iteration-count: 1 !important;
        }
      }
    </style>
  </head>

