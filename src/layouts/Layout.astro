          </ul>
        </div>
      </div>
      <div style="text-align: center; padding-top: 2rem; margin-top: 2rem; border-top: 1px solid rgba(255,255,255,0.1);">
        <p style="color: #F9F7F1;">&copy; 2026 YOGOTOCHINA. All rights reserved.</p>
      </div>
    </footer>

    <!-- ===== 汉堡菜单 ===== -->
    <script>
      // 汉堡菜单
      const hamburger = document.getElementById('hamburger');
      const fullscreenMenu = document.getElementById('fullscreenMenu');

      function toggleMenu() {
        fullscreenMenu.classList.toggle('open');
        document.body.style.overflow = fullscreenMenu.classList.contains('open') ? 'hidden' : '';
      }

      function closeMenu() {
        fullscreenMenu.classList.remove('open');
        document.body.style.overflow = '';
      }

      if (hamburger) {
        hamburger.addEventListener('click', toggleMenu);
      }

      document.querySelectorAll('.fullscreen-menu a:not([data-lang])').forEach(function(link) {
        link.addEventListener('click', closeMenu);
      });
    </script>

    <!-- ===== 语言切换控制 ===== -->
    <script>
      (function() {
        const langBtn = document.getElementById('langToggle');
        const langDropdown = document.getElementById('langDropdown');
        const langCurrent = document.getElementById('langCurrent');
        let isOpen = false;
        let isTranslating = false;

        // 语言名称映射（显示在按钮上）
        const langNames = {
          'en': 'English',
          'zh-TW': '繁體中文',
          'hi': 'हिन्दी',
          'es': 'Español',
          'id': 'Bahasa Indonesia',
          'ar': 'العربية',
          'pt': 'Português',
          'ru': 'Русский',
          'ja': '日本語',
          'fr': 'Français',
          'de': 'Deutsch',
          'it': 'Italiano',
          'ko': '한국어',
          'vi': 'Tiếng Việt',
          'th': 'ภาษาไทย',
          'nl': 'Nederlands'
        };

        // 切换下拉菜单
        function toggleDropdown(e) {
          e.stopPropagation();
          isOpen = !isOpen;
          langDropdown.classList.toggle('open', isOpen);
        }

        // 切换语言
        function changeLanguage(langCode) {
          if (isTranslating) return;
          isTranslating = true;

          // 更新按钮文字
          const langName = langNames[langCode] || langCode;
          langCurrent.textContent = langName;

          // 关闭下拉菜单
          langDropdown.classList.remove('open');
          isOpen = false;

          // 如果选择的是英文，刷新页面恢复原始内容
          if (langCode === 'en') {
            // 关闭全屏菜单
            fullscreenMenu.classList.remove('open');
            document.body.style.overflow = '';
            location.reload();
            return;
          }

          // 调用 GTranslate 切换语言
          try {
            if (window.gtranslate && typeof window.gtranslate.changeLanguage === 'function') {
              window.gtranslate.changeLanguage(langCode);
              isTranslating = false;
              return;
            }

            // 备用方法：通过 URL 参数触发 GTranslate
            const currentUrl = window.location.href.split('?')[0].split('#')[0];
            const newUrl = currentUrl + '?lang=' + langCode;
            window.location.href = newUrl;
          } catch (e) {
            console.error('GTranslate error:', e);
            isTranslating = false;
          }

          setTimeout(function() {
            isTranslating = false;
          }, 3000);
        }

        // 按钮点击事件
        if (langBtn) {
          langBtn.addEventListener('click', toggleDropdown);
        }

        // 点击外部关闭下拉菜单
        document.addEventListener('click', function(e) {
          const wrapper = document.querySelector('.lang-wrapper');
          if (wrapper && !wrapper.contains(e.target)) {
            langDropdown.classList.remove('open');
            isOpen = false;
          }
        });

        // 桌面端语言选项点击事件
        document.querySelectorAll('.lang-dropdown a').forEach(function(link) {
          link.addEventListener('click', function(e) {
            e.preventDefault();
            const lang = this.getAttribute('data-lang');
            if (lang) {
              changeLanguage(lang);
            }
          });
        });

        // 移动端语言切换
        document.querySelectorAll('.fullscreen-menu a[data-lang]').forEach(function(link) {
          link.addEventListener('click', function(e) {
            e.preventDefault();
            const lang = this.getAttribute('data-lang');
            if (lang) {
              // 关闭全屏菜单
              fullscreenMenu.classList.remove('open');
              document.body.style.overflow = '';
              // 切换语言
              changeLanguage(lang);
            }
          });
        });

        // 检测当前语言（从 URL 参数）
        function detectCurrentLang() {
          const urlParams = new URLSearchParams(window.location.search);
          const langParam = urlParams.get('lang');
          if (langParam && langNames[langParam]) {
            langCurrent.textContent = langNames[langParam];
            return langParam;
          }
          return 'en';
        }

        detectCurrentLang();

        if (window.gtranslate && window.gtranslate.getCurrentLanguage) {
          const current = window.gtranslate.getCurrentLanguage();
          if (current && langNames[current]) {
            langCurrent.textContent = langNames[current];
          }
        }

        // 暴露 changeLanguage 到全局
        window.changeLanguage = changeLanguage;

      })();
    </script>

  </body>
</html>