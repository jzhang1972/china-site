            </div>
          </div>
        </li>
      </ul>
    </div>

    <!-- 主要内容 -->
    <main>
      <slot />
    </main>

    <!-- 页脚 -->
    <footer style="background-color: #1F2A2E; color: #F9F7F1; padding: 3rem 1rem 1rem; margin-top: 4rem;">
      <div style="max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 2rem;">
        <div>
          <a href="/" style="color: #FFD700; text-decoration: none;">
            <h3 style="color: #FFD700; margin-bottom: 0.5rem;">YOGOTOCHINA</h3>
          </a>
          <p style="color: #FFFFFF; opacity: 0.8;">China travel, simple and real.</p>
        </div>
        <div>
          <h4 style="color: #FFD700;">Explore</h4>
          <ul style="list-style: none; padding: 0;">
            <li><a href="/stories" style="color: #F9F7F1;">Only in China</a></li>
            <li><a href="/myths" style="color: #F9F7F1;">Myths</a></li>
            <li><a href="/findway" style="color: #F9F7F1;">Routes</a></li>
            <li><a href="/tours" style="color: #F9F7F1;">Tours</a></li>
            <li><a href="/tools" style="color: #F9F7F1;">Before You Go</a></li>
            <li><a href="/visa" style="color: #F9F7F1;">Visa</a></li>
          </ul>
        </div>
        <div>
          <h4 style="color: #FFD700;">Support</h4>
          <ul style="list-style: none; padding: 0;">
            <li><a href="/contact" style="color: #F9F7F1;">Contact Us</a></li>
            <li><a href="/privacy" style="color: #F9F7F1;">Privacy Policy</a></li>
