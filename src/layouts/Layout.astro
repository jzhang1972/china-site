        <!-- 移动端语言切换 -->
        <li style="margin-top: 1.5rem;">
          <div style="display: flex; flex-direction: column; align-items: center; gap: 0.5rem;">
            <span style="color: #6c757d; font-size: 0.85rem;">🌐 Select Language</span>
            <div style="display: flex; flex-wrap: wrap; justify-content: center; gap: 0.4rem; max-width: 400px;">
              <a href="#" data-lang="en" class="lang-link" style="font-size: 0.8rem; color: #1F2A2E; background: #F8F6F0; padding: 0.3rem 0.8rem; border-radius: 30px; text-decoration: none; border: 1px solid #EDEAE0; transition: all 0.2s;">English</a>
              <a href="#" data-lang="zh-TW" class="lang-link" style="font-size: 0.8rem; color: #1F2A2E; background: #F8F6F0; padding: 0.3rem 0.8rem; border-radius: 30px; text-decoration: none; border: 1px solid #EDEAE0; transition: all 0.2s;">繁體中文</a>
              <a href="#" data-lang="hi" class="lang-link" style="font-size: 0.8rem; color: #1F2A2E; background: #F8F6F0; padding: 0.3rem 0.8rem; border-radius: 30px; text-decoration: none; border: 1px solid #EDEAE0; transition: all 0.2s;">हिन्दी</a>
              <a href="#" data-lang="es" class="lang-link" style="font-size: 0.8rem; color: #1F2A2E; background: #F8F6F0; padding: 0.3rem 0.8rem; border-radius: 30px; text-decoration: none; border: 1px solid #EDEAE0; transition: all 0.2s;">Español</a>
              <a href="#" data-lang="id" class="lang-link" style="font-size: 0.8rem; color: #1F2A2E; background: #F8F6F0; padding: 0.3rem 0.8rem; border-radius: 30px; text-decoration: none; border: 1px solid #EDEAE0; transition: all 0.2s;">Bahasa Indonesia</a>
              <a href="#" data-lang="ar" class="lang-link" style="font-size: 0.8rem; color: #1F2A2E; background: #F8F6F0; padding: 0.3rem 0.8rem; border-radius: 30px; text-decoration: none; border: 1px solid #EDEAE0; transition: all 0.2s;">العربية</a>
              <a href="#" data-lang="pt" class="lang-link" style="font-size: 0.8rem; color: #1F2A2E; background: #F8F6F0; padding: 0.3rem 0.8rem; border-radius: 30px; text-decoration: none; border: 1px solid #EDEAE0; transition: all 0.2s;">Português</a>
              <a href="#" data-lang="ru" class="lang-link" style="font-size: 0.8rem; color: #1F2A2E; background: #F8F6F0; padding: 0.3rem 0.8rem; border-radius: 30px; text-decoration: none; border: 1px solid #EDEAE0; transition: all 0.2s;">Русский</a>
