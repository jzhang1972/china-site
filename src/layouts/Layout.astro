---
import "../styles/global.css";

export interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;

const siteTitle = title ? `${title} · YOGOTOCHINA` : 'YOGOTOCHINA · China Travel Guide';
const siteDescription = description || 'Plan your China trip with ease. Visa info, travel guides, routes, real stories, and trusted tours.';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    
    <title>{siteTitle}</title>
    <meta name="description" content={siteDescription} />
    
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={siteDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:image" content="https://yogotochina.com/og-image.jpg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={siteTitle} />
    <meta name="twitter:description" content={siteDescription} />
    <meta name="twitter:image" content="https://yogotochina.com/og-image.jpg" />
    
    <link rel="canonical" href={Astro.url.href} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    
    <!-- ===== 预加载 LCP 图片 ===== -->
    <link rel="preload" as="image" href="/images/hero/tech-chongqing-hongyadong-night-stilt-houses-river-china.webp" fetchpriority="high">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">

    <!-- ===== GTranslate 核心脚本 ===== -->
    <script src="https://cdn.gtranslate.net/widgets/latest/dwf.js" defer></script>

    <style>
      /* ===== 全局重置 ===== */
      * {
        box-sizing: border-box;
      }
      body {
        margin: 0;
        font-family: 'Inter', sans-serif;
        background: #F8F6F0;
        color: #1F2A2E;
      }
      a {
        text-decoration: none;
      }
      img {
        max-width: 100%;
        height: auto;
        display: block;
      }

      /* ===== 导航栏 ===== */
      .navbar {
        background-color: #FFFFFF;
        padding: 0.75rem 1rem;
        position: relative;
        z-index: 100;
        border-bottom: 1px solid #EDEAE0;
      }
      .nav-container {
        max-width: 1200px;
        margin: 0 auto;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      .logo img {
        height: 40px;
        width: auto;
      }

      /* 桌面菜单 */
      .nav-menu {
        display: flex;
        gap: 0.5rem;
        list-style: none;
        margin: 0;
        padding: 0;
        align-items: center;
      }
      .nav-menu li a {
        display: inline-block;
        padding: 0.5rem 1rem;
        color: #1F2A2E;
        text-decoration: none;
        border-radius: 30px;
        font-size: 0.95rem;
        transition: background 0.2s;
      }
      .nav-menu li a:hover {
        background: #F0EDE5;
      }

      /* 语言按钮样式 */
      .lang-wrapper {
        position: relative;
        display: inline-block;
      }
      .lang-btn {
        background: transparent;
        border: 1px solid #EDEAE0;
        border-radius: 30px;
        padding: 0.3rem 0.8rem;
        font-size: 0.85rem;
        color: #1F2A2E;
        cursor: pointer;
        transition: all 0.3s ease;
        font-family: 'Inter', sans-serif;
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
      }
      .lang-btn:hover {
        border-color: #C49E3A;
        background: rgba(196, 158, 58, 0.06);
      }

      .lang-dropdown {
        position: absolute;
        top: calc(100% + 8px);
        right: 0;
        background: #FFFFFF;
        border-radius: 12px;
        box-shadow: 0 8px 32px rgba(0,0,0,0.12);
        border: 1px solid #EDEAE0;
        padding: 0.5rem 0;
        min-width: 160px;
        display: none;
        z-index: 200;
        max-height: 300px;
        overflow-y: auto;
      }
      .lang-dropdown.open {
        display: block;
      }
      .lang-dropdown a {
        display: block;
        padding: 0.4rem 1rem;
        font-size: 0.85rem;
        color: #1F2A2E;
        text-decoration: none;
        transition: background 0.2s;
      }
      .lang-dropdown a:hover {
        background: #F8F6F0;
        color: #C49E3A;
      }

      /* 汉堡按钮（默认隐藏） */
      .hamburger {
        display: none;
        flex-direction: column;
        cursor: pointer;
        padding: 0.25rem;
        background: none;
        border: none;
      }
      .hamburger .bar {
        width: 28px;
        height: 3px;
        background-color: #1F2A2E;
        margin: 3px 0;
        border-radius: 2px;
        transition: 0.3s;
      }

      /* 全屏菜单（默认隐藏） */
      .fullscreen-menu {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: #FFFFFF;
        z-index: 999;
        align-items: center;
        justify-content: center;
        opacity: 0;
        visibility: hidden;
        transition: opacity 0.3s ease, visibility 0.3s ease;
      }
      .fullscreen-menu.open {
        display: flex;
        opacity: 1;
        visibility: visible;
      }
      .fullscreen-menu ul {
        list-style: none;
        text-align: center;
        padding: 0;
        margin: 0;
      }
      .fullscreen-menu ul li {
        margin: 1.5rem 0;
      }
      .fullscreen-menu ul li a {
        font-size: 1.8rem;
        color: #1F2A2E;
        text-decoration: none;
        transition: color 0.2s;
      }
      .fullscreen-menu ul li a:hover {
        color: #C49E3A;
      }

      /* ===== 移动端 ===== */
      @media (max-width: 768px) {
        .nav-menu {
          display: none !important;
        }
        .hamburger {
          display: flex !important;
        }
        .fullscreen-menu {
          display: flex !important;
          opacity: 0;
          visibility: hidden;
        }
        .fullscreen-menu.open {
          opacity: 1;
          visibility: visible;
        }
        .lang-btn {
          font-size: 0.75rem;
          padding: 0.2rem 0.6rem;
        }
        .lang-dropdown {
          min-width: 130px;
          right: -10px;
        }
        /* 全屏菜单中的语言链接样式 */
        .fullscreen-menu .lang-link {
          font-size: 0.85rem !important;
          padding: 0.3rem 0.8rem !important;
          background: #F8F6F0 !important;
          border: 1px solid #EDEAE0 !important;
          border-radius: 30px !important;
          color: #1F2A2E !important;
          text-decoration: none !important;
          display: inline-block !important;
          transition: all 0.2s !important;
        }
        .fullscreen-menu .lang-link:hover {
          background: #EDEAE0 !important;
        }
        .fullscreen-menu .lang-link.active {
          border-color: #C49E3A !important;
          background: rgba(196, 158, 58, 0.08) !important;
        }
      }

      /* ===== 通用卡片 ===== */
      .card-item {
        background: #FFFFFF;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        transition: transform 0.25s ease, box-shadow 0.25s ease;
      }
      .card-item:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 28px rgba(0,0,0,0.10);
      }

      /* ===== 电脑端图片修复 ===== */
      /* 普通内容图片自适应 */
      .content img {
        max-width: 100%;
        height: auto;
      }

      /* 网格卡片图片强制恢复 */
      #grid-start img {
        max-width: none !important;
        width: 100% !important;
        height: 100% !important;
        object-fit: cover !important;
      }

      /* ===== 容器 ===== */
      .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem 1.5rem;
      }

      /* ===== 响应式辅助 ===== */
      @media (max-width: 768px) {
        .container {
          padding: 1rem;
        }
      }

      /* 隐藏 GTranslate 默认渲染 */
      .gt_credit {
        display: none !important;
      }
      .gtranslate_wrapper {
        display: none !important;
      }
    </style>
  </head>
  <body>
    <!-- 导航栏 -->
    <nav class="navbar">
      <div class="nav-container">
        <div class="logo">
          <a href="/">
            <img src="/logo.png" alt="YOGOTOCHINA" height="40">
          </a>
        </div>

        <ul class="nav-menu">
          <li><a href="/">Home</a></li>
          <li><a href="/stories">Only in China</a></li>
          <li><a href="/myths">Myths</a></li>
          <li><a href="/findway">Routes</a></li>
          <li><a href="/tours">Tours</a></li>
          <li><a href="/tools">Before You Go</a></li>
