              <a href="#" data-lang="fr" class="lang-link" style="font-size: 0.8rem; color: #1F2A2E; background: #F8F6F0; padding: 0.3rem 0.8rem; border-radius: 30px; text-decoration: none; border: 1px solid #EDEAE0; transition: all 0.2s;">Français</a>
              <a href="#" data-lang="de" class="lang-link" style="font-size: 0.8rem; color: #1F2A2E; background: #F8F6F0; padding: 0.3rem 0.8rem; border-radius: 30px; text-decoration: none; border: 1px solid #EDEAE0; transition: all 0.2s;">Deutsch</a>
              <a href="#" data-lang="it" class="lang-link" style="font-size: 0.8rem; color: #1F2A2E; background: #F8F6F0; padding: 0.3rem 0.8rem; border-radius: 30px; text-decoration: none; border: 1px solid #EDEAE0; transition: all 0.2s;">Italiano</a>
              <a href="#" data-lang="ko" class="lang-link" style="font-size: 0.8rem; color: #1F2A2E; background: #F8F6F0; padding: 0.3rem 0.8rem; border-radius: 30px; text-decoration: none; border: 1px solid #EDEAE0; transition: all 0.2s;">한국어</a>
              <a href="#" data-lang="vi" class="lang-link" style="font-size: 0.8rem; color: #1F2A2E; background: #F8F6F0; padding: 0.3rem 0.8rem; border-radius: 30px; text-decoration: none; border: 1px solid #EDEAE0; transition: all 0.2s;">Tiếng Việt</a>
              <a href="#" data-lang="th" class="lang-link" style="font-size: 0.8rem; color: #1F2A2E; background: #F8F6F0; padding: 0.3rem 0.8rem; border-radius: 30px; text-decoration: none; border: 1px solid #EDEAE0; transition: all 0.2s;">ภาษาไทย</a>
