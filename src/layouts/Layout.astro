    </nav>

    <!-- 全屏菜单 -->
    <div class="fullscreen-menu" id="fullscreenMenu">
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/stories">Only in China</a></li>
        <li><a href="/myths">Myths</a></li>
        <li><a href="/findway">Routes</a></li>
